<odoo>

    <!-- Tree -->
    <record id="view_loan_proofs_list" model="ir.ui.view">
        <field name="name">loan.proofs.list</field>
        <field name="model">loan.proofs</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
            </list>
        </field>
    </record>

    <!-- Form -->
    <record id="view_loan_proofs_form" model="ir.ui.view">
        <field name="name">loan.proofs.form</field>
        <field name="model">loan.proofs</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name" />
                        <field name="description" />
                        <field name="active" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_loan_proofs" model="ir.actions.act_window">
        <field name="name">Loan Proofs</field>
        <field name="res_model">loan.proofs</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>