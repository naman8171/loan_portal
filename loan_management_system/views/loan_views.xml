<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_loan_loan_list" model="ir.ui.view">
        <field name="name">loan.loan.list</field>
        <field name="model">loan.loan</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="partner_id" />
                <field name="loan_type_id" />
                <field name="application_date" />
                <field name="principal_amount" />
                <field name="disbursed_amount" />
                <field name="next_due_date" />
                <field name="overdue_installment_count" />
                <field name="overdue_amount" />
                <field name="outstanding_amount" />
                <field name="state" />
            </list>
        </field>
    </record>

    <record id="view_loan_loan_form" model="ir.ui.view">
        <field name="name">loan.loan.form</field>
        <field name="model">loan.loan</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" type="object" string="Submit" class="oe_highlight"
                        invisible="state != 'draft'" />
                    <button name="action_approve" type="object" string="Approve"
                        class="oe_highlight" invisible="state != 'submitted'"
                        groups="loan_management_system.group_loan_manager" />
                    <button name="action_open_disburse_wizard" type="object" string="Disburse"
                        class="oe_highlight" invisible="state not in ('approved','open')"
                        groups="loan_management_system.group_loan_manager" />
                    <button name="action_open_loan" type="object" string="Open Loan"
                        invisible="state != 'approved'"
                        groups="loan_management_system.group_loan_manager" />
                    <button name="action_register_payment" type="object" string="Register Payment"
                        class="btn-primary" invisible="state != 'open'" />
                    <button name="action_advance_payment" type="object" string="Advance Payment"
                        invisible="state != 'open'" />
                    <button name="action_open_foreclosure_wizard" type="object" string="Foreclose"
                        invisible="state != 'open'"
                        groups="loan_management_system.group_loan_manager" />
                    <button name="action_close" type="object" string="Close"
                        invisible="state != 'open'"
                        groups="loan_management_system.group_loan_manager" />
                    <button name="action_reject" type="object" string="Reject"
                        invisible="state in ('rejected','closed')"
                        groups="loan_management_system.group_loan_manager" />
                    <button name="action_reset_to_draft" type="object" string="Reset to Draft"
                        invisible="state == 'draft'" />
                    <button name="action_mark_agreement_signed" type="object"
                        string="Mark Agreement Signed"
                        invisible="agreement_signed or state == 'draft'" />
                    <button name="action_create_processing_fee_invoice" type="object"
                        string="Create Processing Fee Invoice"
                        invisible="has_processing_fee_invoice or processing_fee &lt;= 0" />
                    <button name="action_view_processing_fee_invoice" type="object" string="Invoice"
                        invisible="not has_processing_fee_invoice" />
                    <button name="%(action_report_loan_agreement)d" type="action"
                        string="Print Agreement" />
                    <button name="%(action_report_loan_installment)d" type="action"
                        string="Print Installment" />
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,submitted,approved,open,closed" />
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" icon="fa-list"
                            name="action_view_installments">
                            <field name="installment_count" string="Installments" widget="statinfo" />
                        </button>
                        <button class="oe_stat_button" type="object" icon="fa-money"
                            name="action_view_payments">
                            <field name="payment_count" string="Payments" widget="statinfo" />
                        </button>
                        <button class="oe_stat_button" type="object" icon="fa-file-text-o"
                            name="action_view_processing_fee_invoice"
                            invisible="not has_processing_fee_invoice">
                            <span class="o_stat_text">Invoice</span>
                        </button>
                        <button class="oe_stat_button" type="object" icon="fa-bank"
                            name="action_view_disbursements">
                            <field name="disbursement_count" string="Disbursements"
                                widget="statinfo" />
                        </button>
                        <button class="oe_stat_button" type="object" name="action_generate_schedule"
                            icon="fa-calendar"
                            invisible="state not in ('draft','submitted','approved')">
                            <span class="o_stat_text">Generate Schedule</span>
                        </button>
                    </div>

                    <group>
                        <group string="Customer Information">
                            <field name="name" readonly="1" />
                            <field name="partner_id" />
                            <field name="loan_type_id" />
                            <field name="lead_id" />
                            <field name="user_id" />
                            <field name="purpose" />
                        </group>
                        <group string="Loan Details">
                            <field name="application_date" />
                            <field name="approval_date" readonly="1" />
                            <field name="disbursement_date" readonly="1" />
                            <field name="first_due_date" />
                            <field name="grace_period_months" />
                            <field name="term_months" />
                            <field name="agreement_signed" readonly="1" />
                            <field name="agreement_signed_date" readonly="1" />
                            <field name="agreement_signed_by" readonly="1" />
                            <field name="request_source" readonly="1" />
                        </group>
                    </group>

                    <group>
                        <group string="Financial Terms">
                            <field name="principal_amount" />
                            <field name="interest_rate" />
                            <field name="processing_fee" />
                            <field name="processing_fee_not_deducted_from_disbursal" />
                            <field name="penalty_rate" />
                        </group>
                        <group string="Snapshot">
                            <field name="disbursed_amount" readonly="1" />
                            <field name="remaining_to_disburse" readonly="1" />
                            <field name="next_due_date" readonly="1" />
                            <field name="next_due_amount" readonly="1" />
                            <field name="overdue_installment_count" readonly="1" />
                            <field name="overdue_amount" readonly="1" />
                            <field name="paid_amount" readonly="1" />
                            <field name="outstanding_amount" readonly="1" />
                        </group>
                    </group>

                    <group>
                        <group>
                            <field name="total_interest" readonly="1" />
                            <field name="total_fees" readonly="1" />
                        </group>
                        <group>
                            <field name="total_amount" readonly="1" />
                            <field name="settlement_amount" readonly="1" />
                            <field name="foreclosure_date" readonly="1" />
                            <field name="company_id" groups="base.group_multi_company" />
                        </group>
                    </group>

                    <notebook>
                        <page string="Installments">
                            <field name="installment_ids" readonly="state in ('closed','rejected')">
                                <list editable="bottom">
                                    <field name="sequence" readonly="1" />
                                    <field name="due_date" />
                                    <field name="opening_balance" />
                                    <field name="principal_amount" />
                                    <field name="interest_amount" />
                                    <field name="fee_amount" />
                                    <field name="penalty_amount" />
                                    <field name="amount_due" />
                                    <field name="amount_paid" />
                                    <field name="balance_amount" />
                                    <field name="state" />
                                    <field name="late_days" />
                                    <field name="paid_on" />
                                    <button name="action_register_payment" type="object"
                                        string="Pay" class="btn-primary" invisible="state == 'paid'" />
                                </list>
                            </field>
                        </page>
                        <page string="Disbursements">
                            <field name="disbursement_ids" readonly="1">
                                <list>
                                    <field name="name" />
                                    <field name="date" />
                                    <field name="journal_id" />
                                    <field name="amount" />
                                    <field name="state" />
                                    <field name="reference" />
                                </list>
                            </field>
                        </page>
                        <page string="Payments">
                            <field name="payment_ids" readonly="1">
                                <list>
                                    <field name="name" />
                                    <field name="payment_date" />
                                    <field name="journal_id" />
                                    <field name="amount" />
                                    <field name="installment_id" />
                                </list>
                            </field>
                        </page>
                        <page string="Loan Agreement">
                            <field name="agreement_html" widget="html" />
                            <field name="agreement_signature" widget="image" readonly="1" />
                        </page>
                        <page string="Notes">
                            <field name="notes" />
                            <field name="close_note" readonly="1" />
                        </page>
                    </notebook>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>

