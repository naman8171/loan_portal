<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_loan_installment_list" model="ir.ui.view">
        <field name="name">loan.installment.list</field>
        <field name="model">loan.installment</field>
        <field name="arch" type="xml">
            <list>
                <field name="loan_id" />
                <field name="sequence" />
                <field name="due_date" />
                <field name="opening_balance" />
                <field name="principal_amount" />
                <field name="interest_amount" />
                <field name="fee_amount" />
                <field name="penalty_amount" />
                <field name="amount_due" />
                <field name="amount_paid" />
                <field name="balance_amount" />
                <field name="late_days" />
                <field name="state" />
                <field name="paid_on" />
            </list>
        </field>
    </record>

    <record id="view_loan_installment_form" model="ir.ui.view">
        <field name="name">loan.installment.form</field>
        <field name="model">loan.installment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_mark_paid" type="object" string="Mark Paid"
                        class="oe_highlight" invisible="state == 'paid'" />
                    <button name="action_mark_unpaid" type="object" string="Reset Payment"
                        invisible="state == 'unpaid'" />
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="loan_id" />
                            <field name="sequence" />
                            <field name="due_date" />
                            <field name="state" />
                            <field name="late_days" />
                        </group>
                        <group>
                            <field name="opening_balance" />
                            <field name="principal_amount" />
                            <field name="interest_amount" />
                            <field name="fee_amount" />
                            <field name="penalty_amount" />
                            <field name="amount_due" />
                            <field name="amount_paid" />
                            <field name="balance_amount" />
                            <field name="paid_on" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

