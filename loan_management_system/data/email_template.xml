                </p>

                <!-- <p>
                    Our team will proceed with the disbursement process shortly.
                </p> -->

                <br />

                <p> Regards,<br />
                    <strong>Loan Management System</strong>
                </p>

                <!-- VIEW LOAN BUTTON -->
                <p style="margin:20px 0;">
                    <a
                        t-att-href="'%s/web#id=%s&amp;model=loan.loan&amp;view_type=form' % (object.get_base_url(), object.id)"
                        style="background-color:#875A7B;
                              color:#ffffff;
                              padding:10px 18px;
