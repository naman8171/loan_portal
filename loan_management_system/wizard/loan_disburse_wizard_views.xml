<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_loan_disburse_wizard_form" model="ir.ui.view">
        <field name="name">loan.disburse.wizard.form</field>
        <field name="model">loan.disburse.wizard</field>
        <field name="arch" type="xml">
            <form string="Register Disbursement">
                <group>
                    <field name="loan_id" />
                    <field name="date" />
                    <field name="journal_id" />
                    <field name="amount" />
                    <field name="reference" />
                </group>
                <footer>
                    <button string="Confirm" name="action_confirm" type="object" class="btn-primary" />
                    <button string="Cancel" special="cancel" />
                </footer>
            </form>
        </field>
    </record>
    <record id="action_loan_disbursement_report_wizard" model="ir.actions.act_window">
        <field name="name">Loan Disbursement Report</field>
        <field name="res_model">loan.disburse.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>